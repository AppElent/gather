    {
      "@type": "Recipe",
      "name": "Nasi goreng",
      "author": {
        "@id": "https://www.lekkerensimpel.com/#/schema/person/e47d035d8c308aeae2e21bfb3fccb604"
      },
      "description": "Een heerlijk recept om zelf nasi goreng met ei te maken. Lekker met zelfgemaakte satesaus.",
      "datePublished": "2023-01-22T06:00:00+00:00",
      "image": [
        "https://www.lekkerensimpel.com/wp-content/uploads/2021/01/IMG_9161.jpg-1.webp",
        "https://www.lekkerensimpel.com/wp-content/uploads/2021/01/IMG_9161.jpg-1-500x500.webp",
        "https://www.lekkerensimpel.com/wp-content/uploads/2021/01/IMG_9161.jpg-1-500x375.webp",
        "https://www.lekkerensimpel.com/wp-content/uploads/2021/01/IMG_9161.jpg-1-480x270.webp"
      ],
      "recipeYield": [
        "2",
        "2 personen"
      ],
      "cookTime": "PT25M",
      "recipeIngredient": [
        "200 gr rijst (basmati- of witte rijst)",
        "1  kleine rode ui",
        "1  paprika",
        "1  prei",
        "1 teen knoflook",
        "3 el ketjap manis",
        "1 tl sambal",
        "0.5 tl trassi",
        "1 tl komijn",
        "0.5 tl laos",
        "1 tl gedroogde koriander",
        "1 tl kurkuma",
        "1  bosui",
        "2  eieren"
      ],
      "recipeInstructions": [
        {
          "@type": "HowToStep",
          "text": "Begin met het koken van de rijst, volg hiervoor de aanwijzingen op zoals beschreven op de verpakking.",
          "name": "Begin met het koken van de rijst, volg hiervoor de aanwijzingen op zoals beschreven op de verpakking.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-0"
        },
        {
          "@type": "HowToStep",
          "text": "Ondertussen snipper je de ui, pel en snijd je de knoflook fijn en snijd ook de paprika in blokjes.",
          "name": "Ondertussen snipper je de ui, pel en snijd je de knoflook fijn en snijd ook de paprika in blokjes.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-1"
        },
        {
          "@type": "HowToStep",
          "text": "Was de prei en snijd in kleine halve ringen.",
          "name": "Was de prei en snijd in kleine halve ringen.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-2"
        },
        {
          "@type": "HowToStep",
          "text": "Giet het water van de rijst af en laat het liefst de rijst nog even afkoelen.",
          "name": "Giet het water van de rijst af en laat het liefst de rijst nog even afkoelen.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-3"
        },
        {
          "@type": "HowToStep",
          "text": "Giet een scheutje olie in een hapjespan (of wok) en bak de ui, knoflook, paprika en prei aan voor ongeveer 5 minuten. Voeg dan de kruiden toe, even roeren en dan kan de rijst erbij samen met de sambal en ketjap.",
          "name": "Giet een scheutje olie in een hapjespan (of wok) en bak de ui, knoflook, paprika en prei aan voor ongeveer 5 minuten. Voeg dan de kruiden toe, even roeren en dan kan de rijst erbij samen met de sambal en ketjap.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-4"
        },
        {
          "@type": "HowToStep",
          "text": "Bak nog eens 5 minuten.",
          "name": "Bak nog eens 5 minuten.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-5"
        },
        {
          "@type": "HowToStep",
          "text": "Snijd ondertussen een bosuitje in ringetjes en bak een twee spiegeleitjes in een koekenpan.",
          "name": "Snijd ondertussen een bosuitje in ringetjes en bak een twee spiegeleitjes in een koekenpan.",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-6"
        },
        {
          "@type": "HowToStep",
          "text": "Schep de nasi goreng op twee borden, eitjes erbij, pindasaus en eventueel wat kroepoek. Eet smakelijk!",
          "name": "Schep de nasi goreng op twee borden, eitjes erbij, pindasaus en eventueel wat kroepoek. Eet smakelijk!",
          "url": "https://www.lekkerensimpel.com/nasi-goreng-recept/#wprm-recipe-76036-step-0-7"
        }
      ],
