{
  "expo": {
    "name": "Gather",
    "slug": "gather",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gather",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-system-ui"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
