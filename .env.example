# Clerk
# Clerk publishable key (required)
VITE_CLERK_PUBLISHABLE_KEY=
# Test user credentials for the dev-only "log in as test user" button
# (only shown when VITE_CLERK_PUBLISHABLE_KEY is a pk_test_... key)
VITE_TEST_USER_EMAIL=
VITE_TEST_USER_PASSWORD=

# Convex
# Convex deployment name
CONVEX_DEPLOYMENT=
# Convex deployment URL (required)
VITE_CONVEX_URL=

# Sentry (optional — omit to disable Sentry)
# Sentry DSN
VITE_SENTRY_DSN=
# Sentry organization slug
VITE_SENTRY_ORG=
# Sentry project slug
VITE_SENTRY_PROJECT=
# Sentry auth token, used to upload source maps on build
SENTRY_AUTH_TOKEN=
